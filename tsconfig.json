{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "outDir": "dist",
        "baseUrl": "src",
        "rootDir": ".",
        "declaration": true,
        "skipLibCheck": true,
        "importHelpers": true,
        "esModuleInterop": true,
        "isolatedModules": false,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "emitDeclarationOnly": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "lib": [
            "esnext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@core/*": [
                "core/*"
            ],
            "@global/*": [
                "global/*"
            ],
            "@interfaces/*": [
                "interfaces/*"
            ]
        }
    },
    "include": [
        "src/index.ts",
        "src/banner.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "**/*.spec.ts"
    ]
}
